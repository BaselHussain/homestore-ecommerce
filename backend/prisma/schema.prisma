// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password_hash  String
  name           String    @default("")
  email_verified Boolean   @default(false)
  last_login_at  DateTime?
  created_at     DateTime  @default(now())

  cart                  Cart[]
  wishlist              Wishlist[]
  orders                Order[]
  addresses             Address[]
  password_reset_tokens PasswordResetToken[]

  @@map("users")
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  stock         Int
  category      String
  badge         String?
  rating        Decimal? @db.Decimal(3, 2)
  reviews       Int?     @default(0)
  itemCode      String?
  images        Json
  created_at    DateTime @default(now())

  cart_items     Cart[]
  wishlist_items Wishlist[]

  @@map("products")
}

model Cart {
  id         String   @id @default(cuid())
  user_id    String   @map("userId")
  product_id String   @map("productId")
  quantity   Int
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Wishlist {
  id         String   @id @default(cuid())
  user_id    String   @map("userId")
  product_id String   @map("productId")
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@map("wishlist_items")
}

model Order {
  id               String   @id @default(cuid())
  user_id          String?  @map("userId")   // nullable for guest orders
  guest_email      String?  @map("guestEmail")
  total_amount     Decimal  @db.Decimal(10, 2) @map("totalAmount")
  status           String   @default("pending")
  tracking_number  String?  @map("trackingNumber")
  shipping_address Json     @map("shippingAddress")
  items            Json
  created_at       DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@map("orders")
}

model Address {
  id         String   @id @default(cuid())
  user_id    String   @map("userId")
  label      String   @default("Home")
  street     String
  city       String
  state      String
  zip_code   String   @map("zipCode")
  country    String   @default("US")
  is_default Boolean  @default(false) @map("isDefault")
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  user_id    String   @map("userId")
  token      String   @unique
  expires_at DateTime @map("expiresAt")
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model ContactSubmission {
  id         String   @id @default(cuid())
  name       String
  email      String
  message    String
  created_at DateTime @default(now())

  @@map("contact_submissions")
}
